APP_HOST=0.0.0.0
APP_PORT=8088
DATABASE_PATH=./data/agent.sqlite3
MEDIA_DIR=./data/media
SOURCES_PATH=./config/sources.yml

# LLM
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Daily schedule, local server timezone.
DAILY_RUN_HOUR=9
DAILY_RUN_MINUTE=0

# Your style and recommendation knobs.
AUTHOR_NAME=Артем
STYLE_PROFILE_PATH=./config/style_profile.md
STYLE_PROFILES_DIR=./config/styles
RECOMMENDATION_KEYWORDS=AI,ИИ,LLM,агенты,разработка,vibecoding,вайбкодинг,стартап,OpenAI,Claude,Codex

# Telegram publishing and review notifications.
TELEGRAM_BOT_TOKEN=
TELEGRAM_REVIEW_CHAT_ID=
TELEGRAM_CHANNEL_ID=

# VK publishing.
VK_ACCESS_TOKEN=
VK_OWNER_ID=

# Optional Basic Auth for non-public admin/editor pages.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Optional Yandex Zen site verification token.
# If set, the app exposes /zen_<token>.html with the required meta tag.
DZEN_VERIFICATION_TOKEN=
